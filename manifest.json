{
  "manifest_version": 3,
  "name": "Tabby — focus guard",
  "version": "1.7.0",
  "description": "Exact-URL duplicate guard plus optional hostname stack trims — built for deliberate browsing.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["tabs", "webNavigation", "storage", "sessions"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tabby — focus & stack control",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  }
}
